{
  "build": {
    "beforeDevCommand": "yarn dev",
    "beforeBuildCommand": "yarn build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist",
    "withGlobalTauri": false
  },
  "package": {
    "productName": "tickets",
    "version": "../package.json"
  },
  "tauri": {
    "allowlist": {
      "shell": { "open": true },
      "dialog": { "save": true }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.tickets",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ]
    },
    "security": {
      "csp": "default-src 'self'; script-src 'self' https://g.alicdn.com; style-src 'self' 'unsafe-inline'; connect-src 'self' https://mtop.damai.cn https://api.github.com; img-src 'self' data: https:"
    },
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "tickets",
        "width": 1000,
        "height": 800
      }
    ]
  }
}
